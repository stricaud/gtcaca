[gtcaca_theme]
# Consistent blue-desktop / red-button scheme (Debian dialog / ncurses style).
# Anything not listed here keeps the matching built-in default (see
# gtcaca_theme_default in src/theme.c) — statusbar (cyan), inputs (white), etc.
default_bg = blue
default_fg = white

windowfocus_fg = yellow
windowfocus_bg = blue
window_fg = white
window_bg = blue

textfocus_fg = black
textfocus_bg = cyan
text_fg = white
text_bg = blue

buttonfocus_fg = white
buttonfocus_bg = red
button_fg = white
button_bg = blue
